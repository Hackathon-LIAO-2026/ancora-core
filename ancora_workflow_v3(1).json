      "id": "dc-in",
      "name": "Webhook Defesa Civil",
      "webhookId": "defesa-civil-disparo"
    },
    {
      "parameters": {
        "jsCode": "// Parse entrada WAHA — detecta tipo de mídia\nconst body = $input.first().json.body ?? $input.first().json;\nconst msg = body.message ?? body.payload ?? body;\n\nconst mediaUrl = msg.mediaUrl || msg.media?.url || body.mediaUrl || null;\nconst mimetype = msg.mimetype || msg.media?.mimetype || '';\nconst hasImage = !!(mediaUrl && mimetype.startsWith('image/'));\nconst hasAudio = !!(mediaUrl && (mimetype.startsWith('audio/') || mimetype.includes('ogg')));\nconst text = msg.body || msg.text || msg.message || '';\n\nreturn [{ json: {\n  sessionId: (msg.from || body.chatId || 'unknown').replace('@c.us',''),\n  whatsappId: msg.from || body.chatId || '',\n  message: text,\n  nome: msg.pushName || msg.notifyName || 'usuário',\n  hasImage,\n  hasAudio,\n  hasText: !!text && !hasImage && !hasAudio,\n  mediaUrl,\n  mimetype\n}}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-560, 0],
      "id": "parse-waha",
      "name": "Parse WAHA"
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": { "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 3 }, "conditions": [{ "leftValue": "={{ $json.hasImage }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" }, "id": "c-img" }], "combinator": "and" },
              "renameOutput": true, "outputKey": "IMAGEM"
            },
            {
              "conditions": { "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 3 }, "conditions": [{ "leftValue": "={{ $json.hasAudio }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" }, "id": "c-aud" }], "combinator": "and" },
              "renameOutput": true, "outputKey": "AUDIO"
            },
            {
              "conditions": { "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 3 }, "conditions": [{ "leftValue": "={{ $json.hasText }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" }, "id": "c-txt" }], "combinator": "and" },
              "renameOutput": true, "outputKey": "TEXTO"
            }
          ]
        },
        "options": { "allMatchingOutputs": false }
      },
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.3,
      "position": [-320, 0],
      "id": "tipo-midia",
      "name": "Tipo Mídia?"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Descreva esta imagem de emergência climática em 2 frases: {{ $json.mediaUrl }}",
        "options": { "systemMessage": "Descreva objetivamente: nível de água, danos visíveis, risco. Máximo 2 frases. Se não conseguir ver a imagem, diga 'Imagem recebida — descreva sua situação por texto ou áudio'." }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [-80, -200],
      "id": "vision-agent",
      "name": "Gemini Vision"
    },
    {
      "parameters": { "modelName": "models/gemini-2.5-pro-preview-06-05", "options": { "temperature": 0.1 } },
      "type": "@n8n/n8n-nodes-langchain.lmChatGoogleGemini",
      "typeVersion": 1,
      "position": [-80, 0],
      "id": "gemini-vision-llm",
      "name": "LLM Vision",
      "credentials": { "googlePalmApi": { "id": "6x0jnFsx7dKA1I1Y", "name": "Google Gemini(PaLM) Api account 2" } }
    },
    {
      "parameters": {
        "jsCode": "const desc = $input.first().json.output || $input.first().json.text || 'Foto recebida';\nconst ctx = $('Tipo Mídia?').item.json;\nreturn [{ json: { ...ctx, message: '[FOTO] ' + desc + (ctx.message ? '. ' + ctx.message : ''), hasImage: false, hasText: true }}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [160, -200],
      "id": "merge-foto",
      "name": "Texto + Foto"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Transcreva este áudio fielmente. Apenas o texto falado: {{ $json.mediaUrl }}",
        "options": { "systemMessage": "Transcreva o áudio. Retorne apenas o texto falado sem comentários. Se não conseguir, retorne 'Não consegui ouvir — pode repetir por texto?'" }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [-80, 100],
      "id": "audio-agent",
      "name": "Gemini Transcrição"
    },
    {
      "parameters": { "modelName": "models/gemini-2.5-pro-preview-06-05", "options": { "temperature": 0.1 } },
      "type": "@n8n/n8n-nodes-langchain.lmChatGoogleGemini",
