      "parameters": {
        "jsCode": "\nconst raw = $input.first().json.output ?? $input.first().json.text ?? '';\nlet c;\ntry {\n  const m = raw.match(/\\{[\\s\\S]*\\}/);\n  c = JSON.parse(m ? m[0] : raw);\n} catch(e) {\n  c = {\n    panicScore: 2, riskLevel: 'MEDIO',\n    isSalvador: $('Dados').item.json.isSalvador ?? false,\n    bairroDetectado: $('Dados').item.json.bairro || null,\n    cidadeDetectada: $('Dados').item.json.cidade,\n    tipoRisco: 'DESCONHECIDO', palavrasChave: [],\n    resumoContexto: 'Fallback automático', precisaAbrigo: false, ROUTE: 'INFO'\n  };\n}\nconst d = $('Dados').item.json;\nreturn [{json: {\n  ...c,\n  route: c.ROUTE,\n  sessionId: d.sessionId,\n  message: d.message,\n  nome: d.nome,\n  cidade: d.cidade,\n  bairro: c.bairroDetectado ?? d.bairro,\n  lat: d.lat,\n  lon: d.lon,\n  whatsappId: d.whatsappId,\n  precisaAbrigo: c.panicScore >= 3,\n  showEmergencyButton: c.panicScore >= 5\n}}];\n"
      },
