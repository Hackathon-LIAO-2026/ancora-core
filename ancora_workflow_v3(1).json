      "position": [-80, 300],
      "id": "gemini-audio-llm",
      "name": "LLM Áudio",
      "credentials": { "googlePalmApi": { "id": "6x0jnFsx7dKA1I1Y", "name": "Google Gemini(PaLM) Api account 2" } }
    },
    {
      "parameters": {
        "jsCode": "const trans = $input.first().json.output || $input.first().json.text || '';\nconst ctx = $('Tipo Mídia?').item.json;\nreturn [{ json: { ...ctx, message: '[VOZ] ' + trans, hasAudio: false, hasText: true }}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [160, 100],
      "id": "merge-audio",
      "name": "Texto + Áudio"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=SESSÃO: {{ $json.sessionId }}\nNOME: {{ $json.nome }}\nMENSAGEM: {{ $json.message }}",
        "options": {
          "systemMessage": "# ÁncorA — Classificador v5\n\nClassifique a mensagem. Retorne APENAS JSON.\n\n## PANIC SCORE\n1=informativo, 2=preocupação, 3=alerta, 4=emergência, 5=perigo de vida\n\n[FOTO] com água/enchente → mínimo 3\n[VOZ] com desespero/gritos → mínimo 4\n\n## BAIRROS SALVADOR\nLiberdade, Cajazeiras, Sussuarana, Boca do Rio, Plataforma, Subúrbio, Pau da Lima, Lobato, São Caetano, Valéria, Fazenda Coutos, Mussurunga, Itapuã, Pernambués, Saramandaia, Bom Juá, Calabetão, Sete de Abril.\n\n## SAÍDA\n{\"panicScore\":<1-5>,\"riskLevel\":\"BAIXO|MEDIO|ALTO|CRITICO\",\"isSalvador\":<bool>,\"bairroDetectado\":\"<ou null>\",\"cidadeDetectada\":\"<cidade>\",\"tipoRisco\":\"ALAGAMENTO|DESLIZAMENTO|ENCHENTE|DESCONHECIDO\",\"resumoContexto\":\"<frase>\",\"ROUTE\":\"INFO|SALVADOR\"}\n\nROUTE: panicScore<=2 OU !isSalvador → INFO. panicScore>=3 E isSalvador → SALVADOR"
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [400, 0],
      "id": "classificador",
      "name": "Classificador"
    },
    {
      "parameters": { "modelName": "models/gemini-2.5-pro-preview-06-05", "options": { "temperature": 0.1 } },
      "type": "@n8n/n8n-nodes-langchain.lmChatGoogleGemini",
      "typeVersion": 1,
      "position": [400, 220],
      "id": "gemini-class-llm",
      "name": "LLM Classificador",
      "credentials": { "googlePalmApi": { "id": "6x0jnFsx7dKA1I1Y", "name": "Google Gemini(PaLM) Api account 2" } }
    },
    {
      "parameters": { "sessionIdType": "customKey", "sessionKey": "=cls_{{ $json.sessionId }}", "sessionTTL": 3600, "contextWindowLength": 4 },
      "type": "@n8n/n8n-nodes-langchain.memoryRedisChat",
      "typeVersion": 1.5,
      "position": [520, 220],
      "id": "redis-class",
      "name": "Redis Class",
      "credentials": { "redis": { "id": "S4EAdotBAZvt8Z7P", "name": "Redis account" } }
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.output ?? $input.first().json.text ?? '';\nlet c;\ntry { const m = raw.match(/\\{[\\s\\S]*\\}/); c = JSON.parse(m ? m[0] : raw); }\ncatch(e) { c = { panicScore:2, riskLevel:'MEDIO', isSalvador:false, bairroDetectado:null, cidadeDetectada:'desconhecida', tipoRisco:'DESCONHECIDO', resumoContexto:'Fallback', ROUTE:'INFO' }; }\n\nconst prev = $('Classificador').item.json;\nreturn [{ json: { ...c, route: c.ROUTE, sessionId: prev.sessionId, whatsappId: prev.whatsappId || prev.sessionId, message: prev.message, nome: prev.nome, bairro: c.bairroDetectado || '', showEmergencyButton: c.panicScore >= 5 }}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [640, 0],
      "id": "extract-class",
      "name": "Extrair JSON"
    },
    {
      "parameters": {
        "rules": {
          "values": [
            { "conditions": { "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 3 }, "conditions": [{ "leftValue": "={{ $json.route }}", "rightValue": "INFO", "operator": { "type": "string", "operation": "equals" }, "id": "r-info" }], "combinator": "and" }, "renameOutput": true, "outputKey": "INFO" },
            { "conditions": { "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 3 }, "conditions": [{ "leftValue": "={{ $json.route }}", "rightValue": "SALVADOR", "operator": { "type": "string", "operation": "equals" }, "id": "r-ssa" }], "combinator": "and" }, "renameOutput": true, "outputKey": "SALVADOR" }
          ]
        },
        "options": { "allMatchingOutputs": false }
      },
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.3,
      "position": [860, 0],
      "id": "roteador",
      "name": "Roteador"
    },
