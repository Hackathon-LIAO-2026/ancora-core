        "body": "={{ JSON.stringify({ cidade: $json.cidadeDetectada || 'Salvador', bairro: $json.bairro || '', intencao: ($json.tipoRisco||'').toLowerCase()==='alagamento'?'alagamento':'risco_chuva', panicScore: $json.panicScore, mensagemOriginal: $json.message }) }}",
        "options": { "timeout": 10000 }
